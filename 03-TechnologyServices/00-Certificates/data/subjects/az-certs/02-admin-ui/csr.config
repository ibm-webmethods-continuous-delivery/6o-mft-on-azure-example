[ req ]
default_bits = 2048
default_md = sha256
prompt = no
utf8 = yes
encrypt_key = no
distinguished_name = dn
req_extensions = req_ext

[ dn ]
C = XX
O = IWCD MFT on Azure Example
CN = admin-ui.local

[ req_ext ]
subjectAltName = @my_subject_alt_names
basicConstraints = CA:FALSE
keyUsage = nonRepudiation, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth, clientAuth
subjectKeyIdentifier=hash

[ my_subject_alt_names ]
DNS.1 = admin.example-mft.local
DNS.2 = *.example-mft.local
DNS.3 = mft-admin-node1.local
DNS.4 = mft-admin-node2.local
DNS.5 = mft-admin.local
DNS.6 = localhost
DNS.7 = *.local
IP.1 = 127.0.0.1