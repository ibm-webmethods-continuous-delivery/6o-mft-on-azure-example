  # PKCS12 Keystore (alternative format)
  # Source: 03-web-client/out/rsa/full.chain.key.store.p12
  keystore.p12: REPLACE_WITH_BASE64_ENCODED_P12_KEYSTORE
  
  # JKS Truststore
  # Source: 03-web-client/out/rsa/simple.trust.store.jks
  truststore.jks: REPLACE_WITH_BASE64_ENCODED_JKS_TRUSTSTORE
  
  # PKCS12 Truststore (alternative format)
  # Source: 03-web-client/out/rsa/public.trust.store.p12
  truststore.p12: REPLACE_WITH_BASE64_ENCODED_P12_TRUSTSTORE
  
  # Keystore password (base64 encoded)
