---
# SFTP SSH Keys
apiVersion: v1
kind: Secret
metadata:
  name: mft-sftp-ssh-keys
  labels:
    app.kubernetes.io/name: active-transfer
    app.kubernetes.io/component: certificates
type: Opaque
data:
  # RSA private key
  # Source: 04-sftp-server/out/id_rsa
  id_rsa: REPLACE_WITH_BASE64_ENCODED_PRIVATE_KEY
  
  # RSA public key
  # Source: 04-sftp-server/out/id_rsa.pub
  id_rsa.pub: REPLACE_WITH_BASE64_ENCODED_PUBLIC_KEY

---
# Admin Credentials (Integration Server admin password)
apiVersion: v1
kind: Secret
metadata:
  name: mft-admin-credentials
  labels:
    app.kubernetes.io/name: active-transfer
    app.kubernetes.io/component: credentials
type: Opaque
data:
  # Integration Server admin password (base64 encoded)
  # Default username is "Administrator"
  admin-password: REPLACE_WITH_BASE64_ENCODED_ADMIN_PASSWORD
