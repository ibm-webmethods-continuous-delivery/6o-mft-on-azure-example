apiVersion: v1
kind: ServiceAccount
metadata:
  name: database-user-init-sa
  namespace: default
  labels:
    app: database-user-init
    component: initialization
  annotations:
    # Azure Workload Identity annotation - enables OIDC token exchange
    # This allows the pod to authenticate to Azure using the managed identity
    azure.workload.identity/client-id: "${MFT_IDENTITY_CLIENT_ID}"
    azure.workload.identity/tenant-id: "${TENANT_ID}"
